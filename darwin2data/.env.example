# Darwin S3 credentials — NEVER commit this file
# Source: Rail Data Marketplace (opendata.nationalrail.co.uk)
#
# To set up:
# 1. Copy this file to .env.local (also gitignored)
# 2. Fill in your actual credentials from RDM
# 3. The Rust binary reads from .env.local

DARWIN_S3_BUCKET=darwin.xmltimetable
DARWIN_S3_PREFIX=PPTimetable/
DARWIN_S3_ACCESS_KEY=REPLACE_WITH_YOUR_ACCESS_KEY
DARWIN_S3_SECRET_KEY=REPLACE_WITH_YOUR_SECRET_KEY
DARWIN_S3_REGION=eu-west-1
